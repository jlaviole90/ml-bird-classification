# ── Camera / Stream ─────────────────────────────────────
REOLINK_RTSP_URL=rtsp://admin:YOUR_PASSWORD@192.168.1.21:554//h264Preview_01_main
BIRDCAM_STREAM_URL=https://your-pi.tailnet-name.ts.net/stream.m3u8
FRAME_EXTRACTION_FPS=1.0
MOTION_THRESHOLD=30

# ── Kafka ───────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_RAW_FRAMES_TOPIC=raw-frames
KAFKA_INFERENCE_TOPIC=inference-results
KAFKA_METADATA_TOPIC=enriched-metadata

# ── MinIO / S3 ─────────────────────────────────────────
S3_ENDPOINT_URL=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET_RAW=bird-raw-frames
S3_BUCKET_TRAINING=bird-training-data
S3_BUCKET_MODELS=bird-model-artifacts

# ── PostgreSQL ──────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=birdcatalog
POSTGRES_USER=bird
POSTGRES_PASSWORD=bird_secret

# ── Elasticsearch ───────────────────────────────────────
ELASTICSEARCH_URL=http://elasticsearch:9200

# ── TorchServe ──────────────────────────────────────────
TORCHSERVE_INFERENCE_URL=http://torchserve:8080
TORCHSERVE_MANAGEMENT_URL=http://torchserve:8081
CONFIDENCE_THRESHOLD=0.7

# ── Grafana ─────────────────────────────────────────────
GF_SECURITY_ADMIN_PASSWORD=admin

# ── eBird API ───────────────────────────────────────────
EBIRD_API_KEY=your_ebird_api_key
EBIRD_REGION=US-XX-YYY
EBIRD_LAT=0.0
EBIRD_LNG=0.0
EBIRD_RADIUS_KM=25

# ── Training ────────────────────────────────────────────
WANDB_API_KEY=
WANDB_PROJECT=bird-classification
